# Conexion a PostgreSQL
DATABASE_URL=postgresql://postgres:TU_PASSWORD@127.0.0.1:5432/cobranza_db

# Puerto del API (rest-sistemax usa 3000; aqui usamos 3100)
PORT=3100

# Origen permitido para CORS (frontend Vite). Coma-separado para varios.
CORS_ORIGIN=http://localhost:5173

# Login (un solo usuario)
AUTH_EMAIL=correo@ejemplo.com
AUTH_PASSWORD=cambia-esta-clave
SESSION_SECRET=pon-un-secreto-largo-y-aleatorio-aqui
# true SOLO en produccion (HTTPS). En local dejar false.
COOKIE_SECURE=false

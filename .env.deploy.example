# Variables del docker-compose (renombrar a .env en el servidor).
# Genera valores fuertes: openssl rand -base64 24
DB_PASSWORD=pon-un-password-fuerte
AUTH_EMAIL=correo@ejemplo.com
AUTH_PASSWORD=cambia-esta-clave
SESSION_SECRET=pon-un-secreto-largo-aleatorio

# --- Asistente IA (OPCIONAL) ---
# Lo normal es pegar las keys desde la app (Ajustes), no aqui. Estas son un
# respaldo a nivel servidor. Sin key, el chat avisa y el resto funciona igual.
# Gemini (gratis): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# NVIDIA (gratis, respaldo de texto): https://build.nvidia.com
NVIDIA_API_KEY=
